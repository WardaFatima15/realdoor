# Copy this file to .env and fill in your real key. .env is gitignored and
# vercelignored -- it never gets committed or uploaded to Vercel. On Vercel,
# set OPENAI_API_KEY instead via the dashboard or `vercel env add`.
OPENAI_API_KEY=sk-...
# Optional: override the default model (gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
